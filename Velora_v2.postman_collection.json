    {
      "name": "👤 Customer",
      "item": [
        {
          "name": "Register Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\",\n  \"authView\": \"customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/server/customer",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "server", "customer"]
            }
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.accessToken) pm.collectionVariables.set('customerToken', json.accessToken);",
                  "if (json.refreshToken) pm.collectionVariables.set('refreshToken', json.refreshToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/server/customer/login",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "server", "customer", "login"]
            }
          }
        },
        {
          "name": "Refresh Customer Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/server/customer/token/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "server", "customer", "token", "refresh"]
            }
          }
        },
        {
          "name": "Request Email Verification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"authView\": \"customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/server/customer/email/verify",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "server", "customer", "email", "verify"]
            }
          }
        },
        {
          "name": "Confirm Email Verification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"<email-verification-token>\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/server/customer/email/verify/confirm",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "server", "customer", "email", "verify", "confirm"]
            }
          }
        },
        {
          "name": "Request Password Reset",
          "request": {

            }
          }
        },
        {
          "name": "Add Cart Item",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.cart && json.cart.items && json.cart.items.length > 0) {",
                  "  pm.collectionVariables.set('cartItemId', json.cart.items[0]._id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customerToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 2,\n  \"variant\": {\n    \"selectedColor\": \"Black\",\n    \"selectedSize\": \"M\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/server/cart/item",
              "host": ["{{baseUrl}}"],

        {
          "name": "V1 Server Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/v1/server",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "server"]
            }
          }
        }
      ]

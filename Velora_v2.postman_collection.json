            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"newPassword\": \"NewPassword123!\",\n  \"authView\": \"customer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/server/customer/password-reset",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "server", "customer", "password-reset"]
            }

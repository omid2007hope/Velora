              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 1,\n      \"selectedColor\": \"Black\",\n      \"selectedSize\": \"M\"\n    }\n  ],\n  \"currency\": \"USD\",\n  \"addressSnapshot\": {\n    \"street\": \"500 Market Street\",\n    \"country\": \"United States\",\n    \"city\": \"Austin\",\n    \"postalCode\": \"73301\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/checkout/order",
            "description": "Requires a valid Stripe backend setup because order creation also creates a payment intent."
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                { "key": "token", "value": "{{customerAccessToken}}", "type": "string" }
              ]
            },
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderStatus\": \"processing\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/checkout/order/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Stripe Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "{{webhookSignature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_webhook\",\n  \"object\": \"event\",\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"pi_test_123\"\n    }\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/webhook/stripe",
            "description": "For real Stripe webhook verification, replace webhookSignature with a valid Stripe signature generated from the exact raw body."
          }
        }
      ]
    }
  ]
}
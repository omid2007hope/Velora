    {
      "name": "Customer Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () { pm.response.to.have.status(201); });",
                  "const json = pm.response.json();",
                  "const verificationToken = json.emailVerificationToken || '';",
                  "pm.collectionVariables.set('emailVerificationToken', verificationToken);",
                  "if (pm.environment) { pm.environment.set('emailVerificationToken', verificationToken); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{customerFullName}}\",\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\",\n  \"authView\": \"customer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/customer"
          }
        },
        {
          "name": "Login Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('customerAccessToken', json.token || '');",
                  "pm.collectionVariables.set('customerRefreshToken', json.refreshToken || '');",
                  "if (pm.environment) { pm.environment.set('customerAccessToken', json.token || ''); pm.environment.set('customerRefreshToken', json.refreshToken || ''); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/customer/login"
          }
        },
        {
          "name": "Refresh Customer Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('customerAccessToken', json.token); if (pm.environment) { pm.environment.set('customerAccessToken', json.token); } }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{customerRefreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/customer/token/refresh"
          }
        },
        {
          "name": "Request Customer Email Verification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"authView\": \"customer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/customer/email/verify"
          }
        },
        {
          "name": "Confirm Customer Email Verification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{emailVerificationToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/customer/email/verify/confirm",
            "description": "Uses emailVerificationToken captured from registration when available in non-production."
          }
        },
        {
          "name": "Request Customer Password Reset",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "const token = json.token || '';",
                  "pm.collectionVariables.set('passwordResetToken', token);",
                  "if (pm.environment) { pm.environment.set('passwordResetToken', token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"authView\": \"customer\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/customer/password-reset"
          }
        },
        {
          "name": "Confirm Customer Password Reset",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{passwordResetToken}}\",\n  \"newPassword\": \"Password123!\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": "{{baseUrl}}/server/customer/password-reset/confirm"
          }
        }
      ]
    },

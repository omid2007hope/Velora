    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data._id) pm.collectionVariables.set('orderId', data._id);",
                  "if (data.paymentIntent && data.paymentIntent.providerIntentId) pm.collectionVariables.set('paymentIntentId', data.paymentIntent.providerIntentId);",
                  "if (data.paymentIntent && data.paymentIntent.clientSecret) pm.collectionVariables.set('paymentClientSecret', data.paymentIntent.clientSecret);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"items\": [\n    {\n      \"productId\": \"{{productId}}\",\n      \"quantity\": 2,\n      \"selectedColor\": \"Black\",\n      \"selectedSize\": \"M\"\n    }\n  ],\n  \"shipping\": 5,\n  \"tax\": 1.5,\n  \"currency\": \"usd\",\n  \"addressSnapshot\": {\n    \"street\": \"Stephansplatz 1\",\n    \"country\": \"AT\",\n    \"city\": \"Vienna\",\n    \"postalCode\": \"1010\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/server/checkout/order", "host": ["{{baseUrl}}"], "path": ["server", "checkout", "order"] },
            "description": "Creates an order and stores `orderId`, `paymentIntentId`, and `paymentClientSecret` from the response."
          },
          "response": []
        },
        {
          "name": "List Orders",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "const first = data.data && data.data[0];",
                  "if (first && first._id) pm.collectionVariables.set('orderId', first._id);"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/server/checkout/order", "host": ["{{baseUrl}}"], "path": ["server", "checkout", "order"] }
          },
          "response": []
        },
        {
          "name": "Update Order Status",
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentStatus\": \"paid\",\n  \"orderStatus\": \"processing\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/server/checkout/order/{{orderId}}", "host": ["{{baseUrl}}"], "path": ["server", "checkout", "order", "{{orderId}}"] }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhooks",
      "item": [
        {
          "name": "Stripe Webhook",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "stripe-signature", "value": "{{stripeSignature}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_test_webhook\",\n  \"object\": \"event\",\n  \"type\": \"payment_intent.succeeded\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"{{paymentIntentId}}\",\n      \"metadata\": {\n        \"orderId\": \"{{orderId}}\"\n      }\n    }\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/server/webhook/stripe", "host": ["{{baseUrl}}"], "path": ["server", "webhook", "stripe"] },
            "description": "Useful mainly when `STRIPE_WEBHOOK_SECRET` is unset locally. If the secret is configured, Stripe signature validation will require a real signed payload."
          },
          "response": []
        }
      ]
    }
  ]

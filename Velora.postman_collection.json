          ],
          "request": {
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/server/cart", "host": ["{{baseUrl}}"], "path": ["server", "cart"] },
            "description": "Preferred cart read endpoint. Stores the first cart item's `_id` as `cartItemId` if present."
          },
          "response": []
        },
        {
          "name": "Get Cart (POST Variant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "const firstItem = data.data && data.data.items && data.data.items[0];",

    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Customer",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data._id) pm.collectionVariables.set('customerId', data._id);",
                  "if (data.emailVerificationToken) pm.collectionVariables.set('emailVerificationToken', data.emailVerificationToken);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"{{fullName}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/server/customer", "host": ["{{baseUrl}}"], "path": ["server", "customer"] },
            "description": "Creates a customer account. In non-production mode the API may return `emailVerificationToken`, which this collection stores automatically."
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) pm.collectionVariables.set('token', data.token);",
                  "if (data.refreshToken) pm.collectionVariables.set('refreshToken', data.refreshToken);",
                  "if (data.data && data.data._id) pm.collectionVariables.set('customerId', data.data._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/server/customer/login", "host": ["{{baseUrl}}"], "path": ["server", "customer", "login"] },
            "description": "Logs in and stores `token` and `refreshToken` at collection level."
          },
          "response": []
        },
        {
          "name": "Refresh Access Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) pm.collectionVariables.set('token', data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/server/customer/token/refresh", "host": ["{{baseUrl}}"], "path": ["server", "customer", "token", "refresh"] }
          },
          "response": []
        },
        {
          "name": "Request Email Verification",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) pm.collectionVariables.set('emailVerificationToken', data.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/server/customer/email/verify", "host": ["{{baseUrl}}"], "path": ["server", "customer", "email", "verify"] },
            "description": "Triggers a verification email. In non-production mode the token may be returned and is saved to `emailVerificationToken`."
          },
          "response": []
        },
        {
          "name": "Confirm Email Verification",
          "request": {
            "method": "POST",

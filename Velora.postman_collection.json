            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"{{emailVerificationToken}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/server/customer/email/verify/confirm", "host": ["{{baseUrl}}"], "path": ["server", "customer", "email", "verify", "confirm"] }
          },
          "response": []
        },
